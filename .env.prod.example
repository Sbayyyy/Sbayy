COMPOSE_PROJECT_NAME=sbay

DOMAIN_NAME=syrian-bay.com
FRONTEND_URL=https://syrian-bay.com
FRONTEND_WWW_URL=https://www.syrian-bay.com
APP_PUBLIC_BASE_URL=https://api.syrian-bay.com
NEXT_PUBLIC_API_URL=https://api.syrian-bay.com
NEXT_PUBLIC_API_PROXY_TARGET=http://backend:8080
NEXT_PUBLIC_SUPPORT_EMAIL=support@syrian-bay.com
RUNTIME_SUPPORT_EMAIL=support@syrian-bay.com

API_HOST_PORT=5000
WEB_HOST_PORT=3000

DB_PASSWORD=replace_with_secure_database_password
CONNECTION_STRING=Host=postgres;Port=5432;Database=sbay;Username=sbay;Password=replace_with_secure_database_password

JWT_ISSUER=SBay
JWT_AUDIENCE=SBayClients
JWT_SECRET=replace_with_32_character_minimum_random_secret
JWT_EXP_MINUTES=60

UPLOADS_HOST_PATH=./uploads
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_LOCAL_PUBLIC_BASE_URL=https://api.syrian-bay.com/uploads

PAYMENTS_PROVIDER=mock
PAYMENTS_MOCK_WEBHOOK_SECRET=replace_with_random_webhook_secret
MONETIZATION_CURRENCY=SYP
MONETIZATION_COMMISSION_PERCENT=5
