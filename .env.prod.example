# SBay production environment for an IONOS VPS
# Copy this file to .env.prod and replace every placeholder.

COMPOSE_PROJECT_NAME=sbay

# Domain
DOMAIN_NAME=sbay.example.com
FRONTEND_URL=https://sbay.example.com
APP_PUBLIC_BASE_URL=https://sbay.example.com

# Database
DB_PASSWORD=your_secure_db_password_here

CONNECTION_STRING=Host=postgres;Port=5432;Database=sbay;Username=sbay;Password=your_secure_db_password_here

# JWT
JWT_ISSUER=SBay
JWT_AUDIENCE=SBayClients
JWT_SECRET=your_32_character_minimum_jwt_secret_here
JWT_EXP_MINUTES=60

# Local file storage on the IONOS VPS
STORAGE_LOCAL_PUBLIC_BASE_URL=https://sbay.example.com/uploads

# Monetization and payments
PAYMENTS_PROVIDER=mock
PAYMENTS_MOCK_WEBHOOK_SECRET=replace_with_random_webhook_secret
MONETIZATION_CURRENCY=SYP
MONETIZATION_COMMISSION_PERCENT=5
