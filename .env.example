COMPOSE_PROJECT_NAME=sbay

DB_NAME=sbay
DB_USER=sbay
DB_PASSWORD=sbay_dev_password
DB_HOST_PORT=5432
CONNECTION_STRING=Host=postgres;Port=5432;Database=sbay;Username=sbay;Password=sbay_dev_password
ConnectionStrings__Default=Host=postgres;Port=5432;Database=sbay;Username=sbay;Password=sbay_dev_password

REDIS_HOST_PORT=6379

API_HOST_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
APP_PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
FRONTEND_WWW_URL=http://localhost:3000

JWT_ISSUER=SBay
JWT_AUDIENCE=SBayClients
JWT_SECRET=dev_only_change_me_32_bytes_minimum_value
JWT_EXP_MINUTES=60

STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8080/uploads

CORS_ALLOW_ANY_ORIGIN=true

PAYMENTS_PROVIDER=mock
PAYMENTS_MOCK_WEBHOOK_SECRET=dev_mock_webhook_secret
MONETIZATION_CURRENCY=SYP
MONETIZATION_COMMISSION_PERCENT=5

WEB_HOST_PORT=3000
WEB_PORT=3000
WEB_PUBLIC_ORIGIN=http://localhost:3000
WEB_PUBLIC_API_URL=/api
WEB_PUBLIC_API_PROXY_TARGET=http://backend:8080
NEXT_PUBLIC_SUPPORT_EMAIL=support@syrian-bay.com
RUNTIME_SUPPORT_EMAIL=support@syrian-bay.com
NODE_ENV=production
